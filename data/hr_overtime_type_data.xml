<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 平日加班換現 -->
        <record id="overtime_type_weekday_cash" model="hr.overtime.type">
            <field name="name">平日加班換現</field>
            <field name="type">cash</field>
            <field name="overtime_type_date_rule">weekday</field>
            <field name="request_unit">half_an_hour</field>
            <field name="minimum_overtime">False</field>
            <field name="rule_line_ids" eval="[
                (0, 0, {'name': '一到兩小時',   'from_hrs': 1, 'to_hrs': 2,  'hrs_amount': 1.33333334}),
                (0, 0, {'name': '三到四小時',   'from_hrs': 3, 'to_hrs': 4,  'hrs_amount': 1.66666667}),
            ]"/>
            <field name="leave_line_ids" eval="[
                (0, 0, {'name': '上班時段', 'hour_from': 0.0, 'hour_to': 18.0}),
            ]"/>
        </record>

        <!-- 休息日加班換現 -->
        <record id="overtime_type_day_off_cash" model="hr.overtime.type">
            <field name="name">休息日加班換現</field>
            <field name="type">cash</field>
            <field name="overtime_type_date_rule">day_off</field>
            <field name="request_unit">half_an_hour</field>
            <field name="minimum_overtime">False</field>
            <field name="rule_line_ids" eval="[
                (0, 0, {'name': '一到兩小時',   'from_hrs': 1,  'to_hrs': 2,  'hrs_amount': 1.33333334}),
                (0, 0, {'name': '三到九小時',   'from_hrs': 3,  'to_hrs': 9,  'hrs_amount': 1.66666667}),
                (0, 0, {'name': '十到十二小時', 'from_hrs': 10, 'to_hrs': 12, 'hrs_amount': 2.66666667}),
            ]"/>
            <field name="leave_line_ids" eval="[
                (0, 0, {'name': '早上時段', 'hour_from': 0.0,  'hour_to': 8.0}),
                (0, 0, {'name': '中午休息', 'hour_from': 12.0, 'hour_to': 13.0}),
            ]"/>
        </record>

        <!-- 國定假日加班換現 -->
        <record id="overtime_type_national_holiday_cash" model="hr.overtime.type">
            <field name="name">國定假日加班換現</field>
            <field name="type">cash</field>
            <field name="overtime_type_date_rule">regular_holiday_national_holiday</field>
            <field name="request_unit">half_an_hour</field>
            <field name="minimum_overtime">True</field>
            <field name="rule_line_ids" eval="[
                (0, 0, {'name': '一到八小時',   'from_hrs': 1,  'to_hrs': 8,  'hrs_amount': 1.33333334}),
                (0, 0, {'name': '九到十小時',   'from_hrs': 9,  'to_hrs': 10, 'hrs_amount': 2.33333334}),
                (0, 0, {'name': '十一到十二小時','from_hrs': 11, 'to_hrs': 12, 'hrs_amount': 2.66666667}),
            ]"/>
            <field name="leave_line_ids" eval="[
                (0, 0, {'name': '早上休息', 'hour_from': 0.0,  'hour_to': 8.0}),
                (0, 0, {'name': '中午休息', 'hour_from': 12.0, 'hour_to': 13.0}),
            ]"/>
        </record>

        <!-- 例假日加班換現 -->
        <record id="overtime_type_regular_holiday_cash" model="hr.overtime.type">
            <field name="name">例假日加班換現</field>
            <field name="type">cash</field>
            <field name="overtime_type_date_rule">regular_holiday</field>
            <field name="request_unit">half_an_hour</field>
            <field name="minimum_overtime">False</field>
            <field name="rule_line_ids" eval="[
                (0, 0, {'name': '一到八小時',   'from_hrs': 1,  'to_hrs': 8,  'hrs_amount': 1.00000000}),
                (0, 0, {'name': '九到十小時',   'from_hrs': 9,  'to_hrs': 10, 'hrs_amount': 1.33333334}),
                (0, 0, {'name': '十一到十二小時','from_hrs': 11, 'to_hrs': 12, 'hrs_amount': 1.66666667}),
            ]"/>
            <field name="leave_line_ids" eval="[
                (0, 0, {'name': '早上休息', 'hour_from': 0.0,  'hour_to': 9.0}),
                (0, 0, {'name': '中午休息', 'hour_from': 12.0, 'hour_to': 13.0}),
            ]"/>
        </record>

        <!-- 換休（補休） -->
        <record id="overtime_type_leave" model="hr.overtime.type">
            <field name="name">換休</field>
            <field name="type">leave</field>
            <field name="request_unit">half_an_hour</field>
            <field name="minimum_overtime">False</field>
            <field name="leave_type_id" ref="idx_hrm_19.leave_type_overtime"/>
        </record>

    </data>
</odoo>
