        <!-- 時薪制：精簡規則（基本薪、加班費、勞健保、所得稅、實發） -->
        <record id="structure_hourly_salary" model="hr.payroll.structure">
            <field name="code">PART_TIME</field>
            <field name="name">時薪制</field>
            <field name="rule_ids" eval="[(6, 0, [
                ref('hr_rule_basic'),
                ref('hr_rule_overtime_weekdays_taxable'),
                ref('hr_rule_overtime_day_off_taxable'),
                ref('hr_rule_food'),
                ref('hr_rule_overtime_weekdays'),
                ref('hr_rule_overtime_day_off'),
                ref('hr_rule_add_amount'),
                ref('hr_rule_leave'),
                ref('hr_rule_absent'),
                ref('hr_rule_late_early'),
                ref('hr_rule_labor'),
                ref('hr_rule_healthy'),
                ref('hr_rule_dependents_premium'),
                ref('hr_rule_retire'),
