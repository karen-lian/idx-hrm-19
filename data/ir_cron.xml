<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- 1. 合約狀態自動更新（每日 00:05 UTC）
             draft→open（生效日到達）、open→close（到期） -->
        <record id="cron_update_contract_state" model="ir.cron">
            <field name="name">IDX HRM: 合約狀態自動更新</field>
            <field name="model_id" ref="hr.model_hr_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_update_contract_state()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-06 00:05:00</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
        </record>

        <!-- 2. 忘刷通知（每日 10:30 UTC = 台灣 18:30）
             偵測未打卡且無全天假的員工，發送通知 -->
        <record id="cron_forgot_punch_notification" model="ir.cron">
            <field name="name">IDX HRM: 忘刷打卡通知</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_forgot_punch_notification()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-06 10:30:00</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
        </record>

        <!-- 3. 特休自動分配（每日 00:10 UTC）
             檢查當日是否有員工到達特休週年日，自動建立 allocation -->
        <record id="cron_allocate_annual_leave" model="ir.cron">
            <field name="name">IDX HRM: 特休假自動分配</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
            <field name="state">code</field>
            <field name="code">model._cron_allocate_annual_leave()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-06 00:10:00</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
        </record>

        <!-- 4. 外籍員工居留效期警示（每日 00:15 UTC）
             距效期 60 天內發送 activity 警示給 HR 與員工 -->
        <record id="cron_permit_expiry_alert" model="ir.cron">
            <field name="name">IDX HRM: 外籍員工居留效期警示</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_permit_expiry()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-05-06 00:15:00</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
        </record>

        <!-- 5. 補休過期轉現金（每月 1 日 00:20 UTC）
             將過期未使用補休配額轉換為現金補償記錄 -->
        <record id="cron_compensatory_to_cash" model="ir.cron">
            <field name="name">IDX HRM: 補休過期轉現金</field>
            <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
            <field name="state">code</field>
            <field name="code">model._cron_expire_compensatory_to_cash()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="nextcall">2026-06-01 00:20:00</field>
            <field name="numbercall">-1</field>
            <field name="active">1</field>
        </record>

    </data>
</odoo>
