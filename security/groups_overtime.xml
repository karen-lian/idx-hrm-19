<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- 第二層：Privilege（Odoo 19）
             category_id = base.module_category_human_resources -->
        <record id="privilege_overtime" model="res.groups.privilege">
            <field name="name">加班</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>

        <!-- 第三層：Groups -->
        <record id="group_overtime_approver" model="res.groups">
            <field name="name">審批人</field>
            <field name="privilege_id" ref="idx_hrm_19.privilege_overtime"/>
        </record>

        <record id="group_overtime_all_approver" model="res.groups">
            <field name="name">所有審批人</field>
            <field name="privilege_id" ref="idx_hrm_19.privilege_overtime"/>
            <field name="implied_ids" eval="[(4, ref('idx_hrm_19.group_overtime_approver'))]"/>
        </record>

        <record id="group_overtime_manager" model="res.groups">
            <field name="name">管理員</field>
            <field name="privilege_id" ref="idx_hrm_19.privilege_overtime"/>
            <field name="implied_ids" eval="[(4, ref('idx_hrm_19.group_overtime_all_approver'))]"/>
        </record>
    </data>
</odoo>
