<?xml version="1.0" encoding="utf-8"?>
<!-- PR-060：IDX HRM 角色與 Security Groups -->
<odoo>
    <data>
        <!-- Category -->
        <record id="module_hr_idx" model="ir.module.category">
            <field name="name">IDX HRM 台灣</field>
            <field name="sequence">100</field>
        </record>

        <!-- Group 1：一般員工（只能看自己的資料） -->
        <record id="group_hr_idx_employee" model="res.groups">
            <field name="name">一般員工</field>
            <field name="category_id" ref="module_hr_idx"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Group 2：部門主管（可看所屬部門） -->
        <record id="group_hr_idx_manager" model="res.groups">
            <field name="name">部門主管</field>
            <field name="category_id" ref="module_hr_idx"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_idx_employee'))]"/>
        </record>

        <!-- Group 3：薪資管理員（可存取薪資資料） -->
        <record id="group_hr_idx_payroll" model="res.groups">
            <field name="name">薪資管理員</field>
            <field name="category_id" ref="module_hr_idx"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_idx_manager'))]"/>
        </record>

        <!-- Group 4：HR 系統管理員（全存取） -->
        <record id="group_hr_idx_admin" model="res.groups">
            <field name="name">HR 系統管理員</field>
            <field name="category_id" ref="module_hr_idx"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_idx_payroll')), (4, ref('hr.group_hr_manager'))]"/>
        </record>
    </data>
</odoo>
