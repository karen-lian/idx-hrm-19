<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_annual_leave_view_list" model="ir.ui.view">
        <field name="name">hr.annual.leave.view.list</field>
        <field name="model">hr.annual.leave</field>
        <field name="arch" type="xml">
            <list string="特休年資對照表" editable="bottom">
                <field name="tenure_from"/>
                <field name="tenure_to"/>
                <field name="leave_days"/>
                <field name="is_incremental"/>
                <field name="incremental_base_tenure"
                       attrs="{'column_invisible': [('parent.is_incremental','=',False)]}"/>
                <field name="incremental_base_days"
                       attrs="{'column_invisible': [('parent.is_incremental','=',False)]}"/>
                <field name="incremental_max_days"
                       attrs="{'column_invisible': [('parent.is_incremental','=',False)]}"/>
            </list>
        </field>
    </record>

    <record id="action_hr_annual_leave" model="ir.actions.act_window">
        <field name="name">特休年資對照表</field>
        <field name="res_model">hr.annual.leave</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
