<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PR-020/020b：補登出勤申請 -->
    <record id="view_hr_attendance_online_form" model="ir.ui.view">
        <field name="name">hr.attendance.online.form</field>
        <field name="model">hr.attendance.online</field>
        <field name="arch" type="xml">
            <form string="補登出勤申請">
                <header>
                    <button name="action_submit" string="提交審核" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" string="核准" type="object"
                            class="btn-success" groups="hr.group_hr_manager"
                            invisible="state != 'pending'"/>
                    <button name="action_reject" string="駁回" type="object"
                            class="btn-danger" groups="hr.group_hr_manager"
                            invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved"/>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="apply_date"/>
                        </group>
                        <group>
                            <field name="check_in"/>
                            <field name="check_out"/>
                            <field name="approver_id" readonly="1"/>
                            <field name="approval_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                        <field name="rejection_reason" readonly="1"
                               invisible="state != 'rejected'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_attendance_online_list" model="ir.ui.view">
        <field name="name">hr.attendance.online.list</field>
        <field name="model">hr.attendance.online</field>
        <field name="arch" type="xml">
            <list string="補登出勤申請">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="apply_date"/>
                <field name="check_in"/>
                <field name="check_out"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- PR-022：出勤異常紀錄 -->
    <record id="view_hr_attendance_abnormal_list" model="ir.ui.view">
        <field name="name">hr.attendance.abnormal.absence.record.list</field>
        <field name="model">hr.attendance.abnormal.absence.record</field>
        <field name="arch" type="xml">
            <list string="出勤異常紀錄" decoration-danger="not is_resolved">
                <field name="employee_id"/>
                <field name="abnormal_date"/>
                <field name="type"/>
                <field name="minutes"/>
                <field name="deduction_amount"/>
                <field name="audit_state"/>
                <field name="is_resolved"/>
            </list>
        </field>
    </record>

    <!-- PR-024：月度出勤結算 -->
    <record id="view_hr_attendance_month_list" model="ir.ui.view">
        <field name="name">hr.attendance.month.list</field>
        <field name="model">hr.attendance.month</field>
        <field name="arch" type="xml">
            <list string="月度出勤結算">
                <field name="employee_id"/>
                <field name="period"/>
                <field name="late_count"/>
                <field name="late_minutes"/>
                <field name="absent_days"/>
                <field name="deduction_total"/>
                <field name="perfect_attendance"/>
                <field name="perfect_attendance_bonus"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hr_attendance_month_form" model="ir.ui.view">
        <field name="name">hr.attendance.month.form</field>
        <field name="model">hr.attendance.month</field>
        <field name="arch" type="xml">
            <form string="月度出勤結算">
                <sheet>
                    <group col="2">
                        <group string="基本資訊">
                            <field name="employee_id"/>
                            <field name="year"/>
                            <field name="month"/>
                            <field name="period" readonly="1"/>
                            <field name="state"/>
                        </group>
                        <group string="全勤">
                            <field name="perfect_attendance" readonly="1"/>
                            <field name="perfect_attendance_bonus" readonly="1"/>
                        </group>
                    </group>
                    <group string="出勤統計">
                        <group>
                            <field name="work_days"/>
                            <field name="late_count"/>
                            <field name="late_minutes"/>
                            <field name="early_leave_count"/>
                            <field name="early_leave_minutes"/>
                        </group>
                        <group>
                            <field name="absent_days"/>
                            <field name="leave_hours"/>
                            <field name="overtime_hours"/>
                            <field name="deduction_total" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
