<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PR-014/015/016/016b：hr.version（薪資版本）台灣法規擴充表單 -->

    <!-- 新增獨立 hr.version 表單（含台灣法規欄位與審核流程） -->
    <record id="view_hr_version_form_idx" model="ir.ui.view">
        <field name="name">hr.version.form.idx</field>
        <field name="model">hr.version</field>
        <field name="arch" type="xml">
            <form string="薪資版本">
                <header>
                    <field name="approval_state" widget="statusbar"
                           statusbar_visible="draft,pending,approved"/>
                    <button name="action_submit_for_approval"
                            string="提交審核"
                            type="object"
                            class="btn-primary"
                            invisible="approval_state != 'draft'"/>
                    <button name="action_approve"
                            string="核准"
                            type="object"
                            class="btn-success"
                            groups="hr.group_hr_manager"
                            invisible="approval_state != 'pending'"/>
                    <button name="action_reject"
                            string="駁回"
                            type="object"
                            class="btn-danger"
                            groups="hr.group_hr_manager"
                            invisible="approval_state != 'pending'"/>
                    <button name="action_furlough"
                            string="轉留停"
                            type="object"
                            groups="hr.group_hr_manager"
                            invisible="not is_current or change_reason == 'furlough'"/>
                </header>
                <sheet>
                    <group>
                        <group string="基本資料">
                            <field name="employee_id"/>
                            <field name="name"/>
                            <field name="date_version" string="生效日期"/>
                            <field name="contract_date_start"/>
                            <field name="contract_date_end"/>
                        </group>
                        <group string="薪資">
                            <field name="wage"/>
                            <field name="hour_salary" readonly="1"/>
                            <field name="hour_leave_salary" readonly="1"/>
                            <field name="structure_type_id"/>
                            <field name="contract_type_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="台灣法規">
                            <group col="2">
                                <group string="版本資訊">
                                    <field name="change_reason"/>
                                    <field name="job_level"/>
                                    <field name="job_class"/>
                                    <field name="is_part_time"/>
                                    <field name="no_seniority"/>
                                    <field name="is_no_pr"/>
                                    <field name="no_resident" readonly="1"/>
                                </group>
                                <group string="勞健保費率">
                                    <field name="labor_insurance_premium_employee"/>
                                    <field name="health_insurance_premium_employee"/>
                                    <field name="labor_insurance_premium_employer"/>
                                    <field name="health_insurance_premium_employer"/>
                                    <field name="pension_employer"/>
                                </group>
                            </group>
                            <separator string="審核資訊"
                                       invisible="approval_state == 'draft'"/>
                            <group col="2" invisible="approval_state == 'draft'">
                                <field name="approver_id" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                                <field name="rejection_reason" readonly="1"
                                       invisible="approval_state != 'rejected'"/>
                            </group>
                        </page>
                        <page string="健保眷屬">
                            <field name="dependent_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="relationship"/>
                                    <field name="enroll_date"/>
                                    <field name="withdraw_date"/>
                                    <field name="is_active_insured"/>
                                    <field name="health_insurance_premium"/>
                                </list>
                            </field>
                            <group>
                                <field name="dependent_count" readonly="1"/>
                                <field name="dependent_health_insurance_total" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- hr.version list view 擴充：加入台灣法規欄位 -->
    <record id="view_hr_version_list_idx" model="ir.ui.view">
        <field name="name">hr.version.list.idx</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr.hr_version_list_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="change_reason" optional="hide"/>
                <field name="approval_state" optional="show"/>
                <field name="hour_salary" optional="hide"/>
            </xpath>
        </field>
    </record>

    <!-- 獨立 hr.version 管理動作（含表單） -->
    <record id="action_hr_version_tw" model="ir.actions.act_window">
        <field name="name">薪資版本管理</field>
        <field name="res_model">hr.version</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('hr.hr_version_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_hr_version_form_idx')}),
        ]"/>
        <field name="domain">[('employee_id', '!=', False)]</field>
        <field name="search_view_id" ref="hr.hr_version_search_view"/>
        <field name="context">{'search_default_running_contract': 1}</field>
    </record>
</odoo>
