        <field name="name">hr.late.early.criterion.view.list</field>
        <field name="model">hr.late.early.criterion</field>
        <field name="arch" type="xml">
            <list string="遲到早退扣款標準" editable="bottom">
                <field name="minute_from"/>
                <field name="minute_to"/>
                <field name="deduction"/>
            </list>
        </field>
    </record>

    <record id="action_hr_late_early_criterion" model="ir.actions.act_window">
        <field name="name">遲到早退扣款標準</field>
        <field name="res_model">hr.late.early.criterion</field>
        <field name="view_mode">list</field>
    </record>
