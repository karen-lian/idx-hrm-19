<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_overtime" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.overtime</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='payroll']" position="inside">
                <block title="加班模組設定" name="overtime_settings">
                    <setting string="加班免稅額時數">
                        <field name="overtime_taxfree_time"/>
                        <span> 小時</span>
                    </setting>
                    <setting string="工作日加班上限時數" help="單日最高加班時數">
                        <field name="workday_limit_hours"/>
                        <span> 小時</span>
                    </setting>
                    <setting string="單月加班上限時數" help="單月最高加班時數">
                        <field name="overtime_hour_month"/>
                        <span> 小時</span>
                    </setting>
                    <setting string="非工作日加班上限時數" help="單日最高加班時數">
                        <field name="holiday_limit_hour"/>
                        <span> 小時</span>
                    </setting>
                    <setting string="三個月內加班上限時數" help="三個月內最高加班時數">
                        <field name="overtime_hour_three_month"/>
                        <span> 小時</span>
                    </setting>
                    <setting string="加班申請超過參數設定管理辦法">
                        <field name="overtime_regulation" widget="radio"/>
                    </setting>
                    <setting string="加班申請預設類型">
                        <field name="overtime_type" widget="radio"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="action_overtime_config_settings" model="ir.actions.act_window">
        <field name="name">加班設定</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'idx_hrm_19'}</field>
    </record>
</odoo>
