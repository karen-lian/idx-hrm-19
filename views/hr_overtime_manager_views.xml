<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         拒絕原因 Wizard view
    ============================================================ -->
    <record id="view_hr_overtime_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.overtime.reject.wizard.form</field>
        <field name="model">hr.overtime.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="拒絕加班申請">
                <group>
                    <field name="reason" placeholder="請填寫拒絕原因..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="確認拒絕" type="object"
                            class="btn-danger"/>
                    <button string="取消" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_overtime_reject_wizard" model="ir.actions.act_window">
        <field name="name">拒絕原因</field>
        <field name="res_model">hr.overtime.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_overtime_id': active_id}</field>
    </record>

    <!-- ============================================================
         加班管理 form view（審批人視角，繼承員工 form）
         差異：補休分配起始日可寫、加入核准/拒絕按鈕
    ============================================================ -->
    <record id="view_hr_overtime_manager_form" model="ir.ui.view">
        <field name="name">hr.overtime.manager.form</field>
        <field name="model">hr.overtime</field>
        <field name="inherit_id" ref="idx_hrm_19.view_hr_overtime_form"/>
        <field name="arch" type="xml">
            <!-- 在 header 的 退回 按鈕之後，加入 核准 / 拒絕 -->
            <xpath expr="//button[@name='action_return']" position="after">
                <button name="action_approve" string="核准" type="object"
                        class="btn-success"
                        invisible="state != 'pending'"/>
                <button name="%(idx_hrm_19.action_hr_overtime_reject_wizard)d"
                        string="拒絕" type="action"
                        class="btn-danger"
                        invisible="state != 'pending'"/>
            </xpath>
            <!-- 在「加班資訊」group 的 overtime_type_id 後加入補休分配起始日（僅管理人視角可見且可寫） -->
            <xpath expr="//group[@string='加班資訊']/field[@name='overtime_type_id']" position="after">
                <field name="leave_validity_start"
                       invisible="type != 'leave'"
                       required="type == 'leave'"
                       readonly="state not in ('draft', 'pending')"/>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         加班管理 kanban view
    ============================================================ -->
    <record id="view_hr_overtime_kanban" model="ir.ui.view">
        <field name="name">hr.overtime.kanban</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="request_date"/>
                <field name="request_date_to"/>
                <field name="request_hour_from"/>
                <field name="request_hour_to"/>
                <field name="is_cross_day"/>
                <field name="type"/>
                <field name="overtime_type_id"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <!-- 頂部：左邊資訊 ＋ 右上按鈕（一行） -->
                        <div class="d-flex justify-content-between align-items-start">
                            <!-- 左：員工、單號、起訖一行 -->
                            <div class="overflow-hidden">
                                <strong><field name="employee_id"/></strong><br/>
                                <span class="text-muted small"><field name="name"/></span><br/>
                                <div class="small text-nowrap" t-if="!record.is_cross_day.raw_value">
                                    <field name="request_date" class="d-inline"/>從
                                    <field name="request_hour_from" widget="float_time" class="d-inline"/>到
                                    <field name="request_hour_to" widget="float_time" class="d-inline"/>
                                </div>
                                <div class="small text-nowrap" t-if="record.is_cross_day.raw_value">
                                    從 <field name="request_date" class="d-inline"/>
                                    <field name="request_hour_from" widget="float_time" class="d-inline"/>到
                                    <field name="request_date_to" class="d-inline"/>
                                    <field name="request_hour_to" widget="float_time" class="d-inline"/>
                                </div>
                            </div>
                            <!-- 右上：可執行按鈕一行排列 -->
                            <div class="d-flex gap-1 flex-shrink-0 ms-1">
                                <button t-if="record.state.raw_value == 'pending'"
                                        name="action_approve" type="object"
                                        class="btn btn-sm btn-success">核准</button>
                                <button t-if="record.state.raw_value == 'pending'"
                                        name="%(idx_hrm_19.action_hr_overtime_reject_wizard)d"
                                        type="action"
                                        class="btn btn-sm btn-danger">拒絕</button>
                                <button t-if="record.state.raw_value == 'approved'"
                                        name="action_return" type="object"
                                        class="btn btn-sm btn-secondary">退回</button>
                            </div>
                        </div>
                        <!-- 底部：左邊 badge ＋ 右邊狀態 -->
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <div class="d-flex gap-1 flex-wrap">
                                <field name="overtime_type_id" widget="badge"/>
                                <field name="type" widget="badge"
                                       decoration-info="type == 'cash'"
                                       decoration-warning="type == 'leave'"/>
                            </div>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'pending'"
                                   decoration-success="state == 'approved'"
                                   decoration-danger="state == 'rejected'"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         加班管理 action（審批人：看部門/全部）
    ============================================================ -->
    <record id="action_hr_overtime_manager" model="ir.actions.act_window">
        <field name="name">加班管理</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="idx_hrm_19.view_hr_overtime_search"/>
        <field name="context">{'search_default_pending': 1}</field>
        <field name="group_ids" eval="[(6, 0, [ref('idx_hrm_19.group_overtime_approver')])]"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_hr_overtime_kanban')}),
            (0, 0, {'view_mode': 'list',   'view_id': ref('idx_hrm_19.view_hr_overtime_list')}),
            (0, 0, {'view_mode': 'form',   'view_id': ref('view_hr_overtime_manager_form')}),
        ]"/>
    </record>

    <!-- ============================================================
         ir.model.access：hr.overtime.reject.wizard
    ============================================================ -->
</odoo>
