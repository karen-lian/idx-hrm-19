<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         加班申請 form view（員工視角）
    ============================================================ -->
    <record id="view_hr_overtime_form" model="ir.ui.view">
        <field name="name">hr.overtime.form</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <form string="加班申請">
                <header>
                    <button name="action_submit" string="提交" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_return" string="退回" type="object"
                            invisible="state != 'approved'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <!-- 第一列：員工資訊 ＋ 申請時段 並排 -->
                    <group>
                        <group string="員工資訊">
                            <field name="employee_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                            <field name="job_id" readonly="1"/>
                            <field name="manager_id" readonly="1"/>
                        </group>
                        <group string="申請時段">
                            <!-- 跨日旗標 -->
                            <label for="is_cross_day" string="跨日"/>
                            <div>
                                <field name="is_cross_day" class="oe_inline"
                                       readonly="state != 'draft'"/>
                            </div>

                            <!-- 加班日期（非跨日）：[date] 從 [hour_from] 到 [hour_to] -->
                            <label for="request_date" string="加班日期"
                                   invisible="is_cross_day"/>
                            <div invisible="is_cross_day">
                                <field name="request_date" class="oe_inline"
                                       readonly="state != 'draft'"/>
                                <span class="oe_inline mx-1">從</span>
                                <field name="request_hour_from" widget="float_time"
                                       class="oe_inline"
                                       readonly="state != 'draft'"/>
                                <span class="oe_inline mx-1">到</span>
                                <field name="request_hour_to" widget="float_time"
                                       class="oe_inline"
                                       readonly="state != 'draft'"/>
                            </div>

                            <!-- 加班日期（跨日）：從 [date] [hour_from] 到 [date_to] [hour_to] -->
                            <label for="request_date" string="加班日期"
                                   invisible="not is_cross_day"/>
                            <div invisible="not is_cross_day">
                                <span class="oe_inline me-1">從</span>
                                <field name="request_date" class="oe_inline"
                                       readonly="state != 'draft'"/>
                                <field name="request_hour_from" widget="float_time"
                                       class="oe_inline ms-1"
                                       readonly="state != 'draft'"/>
                                <span class="oe_inline mx-1">到</span>
                                <field name="request_date_to" class="oe_inline"
                                       readonly="1"/>
                                <field name="request_hour_to" widget="float_time"
                                       class="oe_inline ms-1"
                                       readonly="state != 'draft'"/>
                            </div>

                            <label for="hours" string="總時數"/>
                            <div>
                                <field name="hours" readonly="1" class="oe_inline"/>
                                <span class="oe_inline ms-1">小時</span>
                            </div>
                        </group>
                    </group>
                    <!-- 第二列：加班資訊（左右兩欄） -->
                    <group string="加班資訊">
                        <group>
                            <field name="leave_allocation_id" readonly="1"
                                   invisible="not leave_allocation_id"/>
                            <field name="type" readonly="state != 'draft'"/>
                            <field name="overtime_type_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="attachment" widget="binary"
                                   filename="attachment_name"
                                   readonly="state != 'draft'"/>
                            <field name="attachment_name" invisible="1"/>
                            <field name="description"
                                   placeholder="請說明加班原因..."
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <!-- 拒絕原因（僅拒絕狀態顯示） -->
                    <group invisible="state != 'rejected'">
                        <field name="return_reason" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         加班申請 list view
    ============================================================ -->
    <record id="view_hr_overtime_list" model="ir.ui.view">
        <field name="name">hr.overtime.list</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <list string="加班申請"
                  decoration-info="state == 'pending'"
                  decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="request_date"/>
                <field name="request_hour_from" widget="float_time" string="開始時間"/>
                <field name="is_cross_day" string="跨日"/>
                <field name="request_hour_to" widget="float_time" string="結束時間"/>
                <field name="hours"/>
                <field name="type"/>
                <field name="overtime_type_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'pending'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         加班申請 search view
    ============================================================ -->
    <record id="view_hr_overtime_search" model="ir.ui.view">
        <field name="name">hr.overtime.search</field>
        <field name="model">hr.overtime</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <filter string="我的申請" name="my_overtime"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="待批准" name="pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="已批准" name="approved"
                        domain="[('state', '=', 'approved')]"/>
                <separator/>
                <filter name="filter_request_date" string="申請日期"
                        date="request_date" default_period="month"/>
                <group>
                    <filter string="員工" name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="狀態" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="申請類型" name="group_type"
                            context="{'group_by': 'type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         加班申請 action（員工：只看自己）
    ============================================================ -->
    <record id="action_hr_overtime_request" model="ir.actions.act_window">
        <field name="name">加班申請</field>
        <field name="res_model">hr.overtime</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="idx_hrm_19.view_hr_overtime_search"/>
        <field name="context">{'search_default_my_overtime': 1}</field>
    </record>
</odoo>
