<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         hr.overtime.type — List View
    ============================================================ -->
    <record id="hr_overtime_type_view_list" model="ir.ui.view">
        <field name="name">hr.overtime.type.view.list</field>
        <field name="model">hr.overtime.type</field>
        <field name="arch" type="xml">
            <list string="加班時段">
                <field name="name"/>
                <field name="type"/>
                <field name="overtime_type_date_rule"/>
                <field name="request_unit"/>
            </list>
        </field>
    </record>

    <!-- ============================================================
         hr.overtime.type — Form View
    ============================================================ -->
    <record id="hr_overtime_type_view_form" model="ir.ui.view">
        <field name="name">hr.overtime.type.view.form</field>
        <field name="model">hr.overtime.type</field>
        <field name="arch" type="xml">
            <form string="加班時段">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="加班時段名稱"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type"/>
                            <field name="overtime_type_date_rule"/>
                            <field name="request_unit"/>
                            <field name="minimum_overtime"
                                   invisible="type == 'leave'"/>
                        </group>
                        <group>
                            <field name="leave_type_id"
                                   invisible="type != 'leave'"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook invisible="type != 'cash'">
                        <page string="加班費規則" name="cash_rules">
                            <field name="rule_line_ids">
                                <list editable="bottom" string="費率規則">
                                    <field name="name"/>
                                    <field name="from_hrs"/>
                                    <field name="to_hrs"/>
                                    <field name="hrs_amount"/>
                                    <field name="no_taxable"/>
                                </list>
                            </field>
                            <separator string="休息時間"/>
                            <field name="leave_line_ids">
                                <list editable="bottom" string="休息時間">
                                    <field name="name"/>
                                    <field name="hour_from" widget="float_time"/>
                                    <field name="hour_to" widget="float_time"/>
                                    <field name="hrs" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Action：加班時段
    ============================================================ -->
    <record id="action_hr_overtime_config_type" model="ir.actions.act_window">
        <field name="name">加班時段</field>
        <field name="res_model">hr.overtime.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
