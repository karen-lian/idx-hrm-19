<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_overtime_config_view_form" model="ir.ui.view">
        <field name="name">hr.overtime.config.view.form</field>
        <field name="model">hr.overtime.config</field>
        <field name="arch" type="xml">
            <form string="加班設定">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="monthly_limit_hours"/>
                        <field name="daily_limit_hours"/>
                    </group>
                    <notebook>
                        <page string="加班時段費率表">
                            <field name="overtime_type_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="day_type"/>
                                    <field name="compensation_type"/>
                                    <field name="leave_conversion_ratio"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_overtime_config_type_view_list" model="ir.ui.view">
        <field name="name">hr.overtime.config.type.view.list</field>
        <field name="model">hr.overtime.config.type</field>
        <field name="arch" type="xml">
            <list string="加班時段" editable="bottom">
                <field name="name"/>
                <field name="day_type"/>
                <field name="compensation_type"/>
                <field name="leave_conversion_ratio"/>
            </list>
        </field>
    </record>

    <record id="action_hr_overtime_config" model="ir.actions.act_window">
        <field name="name">加班設定</field>
        <field name="res_model">hr.overtime.config</field>
        <field name="view_mode">form</field>
    </record>

    <record id="action_hr_overtime_config_type" model="ir.actions.act_window">
        <field name="name">加班時段</field>
        <field name="res_model">hr.overtime.config.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
